# OpenClaw workspace files
.openclaw/
.env
secrets.json
*.log
!**/raw_data/*.log
node_modules/
__pycache__/
*.pyc
.DS_Store
*.lock
*.tmp
*.swp
*.swo
*~

# HTB runtime proxy files (generated at runtime)
htb/proxy/

# HTB sensitive artifacts — never commit keys, certs, or loot
# SSH private keys
**/id_rsa
**/id_dsa
**/id_ecdsa
**/id_ed25519
**/*.pem
**/*.key

# HTB Academy / Box downloadable artifacts (keep in workspace, not repo)
htb/boxes/active/**/loot/
htb/boxes/active/**/files/
htb/academy/**/files/
htb/academy/**/loot/
